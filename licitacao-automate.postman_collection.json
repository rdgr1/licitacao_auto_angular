    {
      "name": "✅ Testes de Integração",
      "description": "Sequência com assertions automáticas. Rode em ordem (1→6).",
      "item": [
        {
          "name": "1. Health check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('API respondendo', () => pm.response.to.have.status(200));",
                  "pm.test('Status UP', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('UP');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/actuator/health", "host": ["{{base_url}}"], "path": ["actuator", "health"] }
          }
        },
        {
          "name": "2. Stats iniciais",
          "event": [
            {
              "listen": "test",
              "script": {
