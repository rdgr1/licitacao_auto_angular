    {
      "name": "⚙️ Scraping",
      "description": "Disparo manual do pipeline de coleta, reprocessamento e reclassificação.",
      "item": [
        {
          "name": "Disparar scraping (PNCP + scrapers)",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/editais/processar",
              "host": ["{{base_url}}"],
              "path": ["api", "editais", "processar"]
            },
            "description": "Executa o pipeline completo: PNCP + DODF + outros scrapers ativos.\nRetorna: { success, total, processados, erros, mensagensErro }\n\n⚠️ Lança 409 se já houver uma execução em andamento."
          }
        },
        {
          "name": "Reprocessar edital com erro",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/editais/{{edital_id}}/reprocessar",
              "host": ["{{base_url}}"],
              "path": ["api", "editais", "{{edital_id}}", "reprocessar"]
            },
            "description": "Só funciona para editais com status ERRO ou PENDENTE."
          }
        },
        {
          "name": "Reclassificar todos os leads",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/editais/reclassificar",
              "host": ["{{base_url}}"],
              "path": ["api", "editais", "reclassificar"]
            },
            "description": "Recalcula score e categoria de todos os editais PROCESSADO com as regras atuais.\nUsar após editar regras de análise para aplicar ao histórico."
          }
        }
      ]
    },
    {
      "name": "🔔 Notificações",
      "description": "Feed de eventos em tempo real (SSE) e webhook de saída.",
      "item": [
        {
          "name": "Histórico de notificações",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/notificacoes",
              "host": ["{{base_url}}"],
              "path": ["api", "notificacoes"]
            },
            "description": "Últimos 100 eventos NOVO_LEAD em memória (ordem cronológica).\nCada evento: { tipo, timestamp, editalId, numero, objeto, orgao, valorEstimado, leadScore, categoria, urlPncp }"
          }
        },
        {
          "name": "Testar webhook",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/notificacoes/teste",
              "host": ["{{base_url}}"],
              "path": ["api", "notificacoes", "teste"]
            },
            "description": "Dispara evento de teste no webhook configurado (env WEBHOOK_URL).\nÚtil para validar integração com n8n / Slack / WhatsApp / Zapier."
          }
        },
        {
          "name": "SSE stream (tempo real)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "text/event-stream" }],
            "url": {
              "raw": "{{base_url}}/api/notificacoes/stream",
              "host": ["{{base_url}}"],
              "path": ["api", "notificacoes", "stream"]
            },
            "description": "Server-Sent Events — mantém conexão aberta.\n\n⚠️ Postman suporta SSE parcialmente. Teste com:\n  curl -N http://localhost:8080/api/notificacoes/stream\n\nNo Angular:\n  const es = new EventSource('/api/notificacoes/stream');\n  es.addEventListener('NOVO_LEAD', e => {\n    const lead = JSON.parse(e.data);\n    console.log(lead);\n  });"
          }
        }
      ]
    },
    {
      "name": "📐 Regras de Análise",
      "description": "CRUD das regras de classificação de leads — editável pelas funcionárias sem deploy.",
      "item": [
        {
          "name": "Listar todas as regras",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/regras",
              "host": ["{{base_url}}"],
              "path": ["api", "regras"]
            }
          }
        },
        {
          "name": "Listar regras ativas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/regras/ativas",
              "host": ["{{base_url}}"],
              "path": ["api", "regras", "ativas"]
            }
          }
        },
        {
          "name": "Tipos de regra (enum)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/regras/tipos",
              "host": ["{{base_url}}"],
              "path": ["api", "regras", "tipos"]
            },
            "description": "KEYWORD_OBJETO | KEYWORD_ITEM | FAIXA_VALOR | PRAZO_MIN_MAX | MODALIDADE_PERMITIDA | DESCARTE"
          }
        },
        {
          "name": "Categorias disponíveis",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/regras/categorias",
              "host": ["{{base_url}}"],
              "path": ["api", "regras", "categorias"]
            },
            "description": "VIGILANCIA | MAO_DE_OBRA | LIMPEZA | BRIGADA | COPEIRAGEM"
          }
        },
        {
          "name": "Buscar regra por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/regras/{{regra_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "regras", "{{regra_id}}"]
            }
          }
        },
        {
          "name": "Criar — keyword no objeto",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"KEYWORD_OBJETO\",\n  \"nome\": \"Portaria e recepção\",\n  \"descricao\": \"Detecta licitações de portaria e recepção\",\n  \"valorRegra\": \"portaria,recepcao,recepcionista,controle de acesso\",\n  \"peso\": 40,\n  \"categoria\": \"VIGILANCIA\",\n  \"ativa\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/regras",
              "host": ["{{base_url}}"],
              "path": ["api", "regras"]
            },
            "description": "valorRegra: palavras separadas por vírgula (sem acentos, lowercase).\n⚠️ Nome deve ser único — retorna 400 se duplicado."
          }
        },
        {
          "name": "Criar — faixa de valor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"FAIXA_VALOR\",\n  \"nome\": \"Contratos grandes (acima de R$ 2M)\",\n  \"descricao\": \"Bônus para contratos de alto valor\",\n  \"valorRegra\": \"2000000-\",\n  \"peso\": 15,\n  \"categoria\": \"VIGILANCIA\",\n  \"ativa\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/regras",
              "host": ["{{base_url}}"],
              "path": ["api", "regras"]
            },
            "description": "Formato: \"min-max\" em R$.\n  \"100000-5000000\" → entre 100k e 5M\n  \"2000000-\"       → acima de 2M (sem limite superior)\n  \"-500000\"        → abaixo de 500k"
          }
        },
        {
          "name": "Criar — prazo de execução",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"PRAZO_MIN_MAX\",\n  \"nome\": \"Prazo ideal (12 a 60 meses)\",\n  \"descricao\": \"Contratos com prazo entre 1 e 5 anos\",\n  \"valorRegra\": \"365-1825\",\n  \"peso\": 10,\n  \"categoria\": \"MAO_DE_OBRA\",\n  \"ativa\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/regras",
              "host": ["{{base_url}}"],
              "path": ["api", "regras"]
            },
            "description": "Formato: \"min-max\" em dias.\n  \"365-1825\" → entre 1 ano e 5 anos"
          }
        },
        {
          "name": "Criar — modalidade permitida",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"MODALIDADE_PERMITIDA\",\n  \"nome\": \"Modalidades preferidas — pregão e concorrência\",\n  \"descricao\": \"Bônus para modalidades que a empresa opera melhor\",\n  \"valorRegra\": \"PREGAO_ELETRONICO,CONCORRENCIA_ELETRONICA,DISPENSA\",\n  \"peso\": 5,\n  \"categoria\": \"VIGILANCIA\",\n  \"ativa\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/regras",
              "host": ["{{base_url}}"],
              "path": ["api", "regras"]
            },
            "description": "Modalidades disponíveis: PREGAO_ELETRONICO | PREGAO_PRESENCIAL | CONCORRENCIA_ELETRONICA | CONCORRENCIA_PRESENCIAL | DISPENSA | INEXIGIBILIDADE | OUTRO"
          }
        },
        {
          "name": "Criar — descarte",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"DESCARTE\",\n  \"nome\": \"Descarte — TI e suporte técnico\",\n  \"descricao\": \"Descarta licitações de TI que não são nosso foco\",\n  \"valorRegra\": \"suporte de ti,helpdesk,desenvolvimento de software,sistema de informacao,infraestrutura de rede\",\n  \"peso\": 0,\n  \"categoria\": null,\n  \"ativa\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/regras",
              "host": ["{{base_url}}"],
              "path": ["api", "regras"]
            },
            "description": "Regras DESCARTE têm prioridade total — se a keyword encontrar, score vai a 0 e o edital não aparece como lead."
          }
        },
        {
          "name": "Atualizar regra",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"KEYWORD_OBJETO\",\n  \"nome\": \"Vigilância — keywords ampliadas\",\n  \"descricao\": \"Inclui CFTV e controle de acesso\",\n  \"valorRegra\": \"vigilancia,vigilância,seguranca,segurança,monitoramento,portaria,ronda,escolta,cftv,controle de acesso\",\n  \"peso\": 55,\n  \"categoria\": \"VIGILANCIA\",\n  \"ativa\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/regras/{{regra_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "regras", "{{regra_id}}"]
            }
          }
        },
        {
          "name": "Ativar / Desativar (toggle)",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/regras/{{regra_id}}/toggle",
              "host": ["{{base_url}}"],
              "path": ["api", "regras", "{{regra_id}}", "toggle"]
            },
            "description": "Alterna ativa ↔ inativa sem precisar mandar o objeto completo."
          }
        },
        {
          "name": "Deletar regra",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/regras/{{regra_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "regras", "{{regra_id}}"]
            }
          }
        }
      ]
