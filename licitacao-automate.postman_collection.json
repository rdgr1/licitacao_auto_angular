              "raw": "{{base_url}}/api/editais/search?q=vigilancia",
              "host": ["{{base_url}}"],
              "path": ["api", "editais", "search"],
              "query": [{ "key": "q", "value": "vigilancia", "description": "Busca no número e no objeto" }]
