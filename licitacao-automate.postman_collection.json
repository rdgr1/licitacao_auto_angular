              "query": [{ "key": "status", "value": "ANTECIPADO" }]
            },
            "description": "Editais detectados via DOU/DODF antes de aparecerem no PNCP.\nStatus disponíveis: ANTECIPADO | PENDENTE | PROCESSANDO | PROCESSADO | ERRO | ARQUIVADO"
          }
