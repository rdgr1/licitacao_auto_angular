            "header": [],
            "url": {
              "raw": "{{base_url}}/api/editais/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "editais", "stats"]
            },
            "description": "Retorna: totalEditais, processados, pendentes, erros, valorTotalEstimado, ultimaExecucao."
          }
        },
        {
          "name": "Deletar edital",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/editais/{{edital_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "editais", "{{edital_id}}"]
            },
            "description": "⚠️ Irreversível."
          }
        }
      ]
    },
