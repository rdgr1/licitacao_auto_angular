{
  "info": {
    "_postman_id": "licitacao-automate-api-v2",
    "name": "licitacao-automate API",
    "description": "Collection completa — sistema de automação de licitações.\n\n**Variáveis de coleção:**\n- `base_url` → http://localhost:8080\n- `edital_id` → ID de edital para testes\n- `regra_id` → ID de regra para testes\n\n**Módulos:**\n1. 📋 Editais — feed, busca, filtros\n2. 🏆 Leads — leads qualificados por score\n3. ⚙️ Scraping — disparo manual, reprocessamento, reclassificação\n4. 🔔 Notificações — histórico SSE + teste de webhook\n5. 📐 Regras de Análise — CRUD configurável\n6. 🩺 Health & Métricas — actuator\n7. ✅ Testes de Integração — fluxo ponta a ponta com assertions",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "edital_id", "value": "1", "type": "string" },
    { "key": "edital_numero", "value": "", "type": "string" },
    { "key": "regra_id", "value": "1", "type": "string" },
    { "key": "total_inicial", "value": "0", "type": "string" },
    { "key": "total_processados", "value": "0", "type": "string" }
  ],
  "item": [
    {
      "name": "📋 Editais",
      "description": "Consulta e gestão de editais de licitação.",
      "item": [
        {
          "name": "Listar todos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/editais",
              "host": ["{{base_url}}"],
              "path": ["api", "editais"]
